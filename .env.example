# ═══════════════════════════════════════════
# Bristol Care Dashboard — Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env.local:
#   cp .env.example .env.local
# ═══════════════════════════════════════════

# ── Supabase (可选，不配置时使用 localStorage) ──
# 不配置时 App 以本地模式运行，数据保存在浏览器中。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 服务端密钥（仅服务端，不暴露到浏览器）
# 不配置时 admin API 和云端同步不可用。
SUPABASE_SERVICE_ROLE_KEY=

# ── 必选 ──
# 默认空间访问码，用于标识情侣共享空间。
# 建议保持与 Supabase couple_spaces 表中的 code 一致。
NEXT_PUBLIC_DEFAULT_SPACE_CODE=xiaoguai520

# ── Admin ──
# 后台管理密码，访问 /admin 时需要输入。
# 请设置为只有自己知道的密码。
ADMIN_PASSWORD=

# ── Push 通知 (可选，不配置时推送功能不可用但不影响 App) ──
# 运行 npm run generate:vapid 生成密钥对。
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID subject，通常为 mailto:you@example.com
VAPID_SUBJECT=
